@page
@using WebUI.Pages.Account
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">GoBike - Login</h2>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @Model.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" asp-action="Login">
                        <div class="mb-3">
                            <label for="Input_Username" class="form-label">Username</label>
                            <input type="text" class="form-control" id="Input_Username" asp-for="Input.Username" required>
                        </div>

                        <div class="mb-3">
                            <label for="Input_Password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="Input_Password" asp-for="Input.Password" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Login</button>
                    </form>

                    <hr>
                    <p class="text-center text-muted">
                        <small>Demo Credentials:<br>
                        Admin: admin / admin123<br>
                        Staff: staff / staff123
                        </small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }
</style>
