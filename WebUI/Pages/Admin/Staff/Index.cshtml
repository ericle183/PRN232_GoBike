@page
@model WebUI.Pages.Admin.Staff.IndexModel
@{
    ViewData["Title"] = "Staff Users";
    Layout = "/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Staff Users</h2>
    <a asp-page="Create" class="btn btn-primary">+ Add Staff</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.StaffUsers.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No staff users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model.StaffUsers)
                    {
                        <tr>
                            <td><code>@user.Username</code></td>
                            <td>@user.FullName</td>
                            <td>@(user.Email ?? "-")</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline"
                                      onsubmit="return confirm('Delete staff user @user.Username?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
