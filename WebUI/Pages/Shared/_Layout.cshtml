@{
    var currentPath = Context.Request.Path.ToString().ToLowerInvariant();
    var isAdmin = User.IsInRole("Admin");
    var isStaff = User.IsInRole("Staff");
    var displayName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
        ?? User.Identity?.Name
        ?? "User";
    var roleLabel = isAdmin ? "ADMIN" : isStaff ? "STAFF" : null;
    var roleClass = isAdmin ? "admin" : "";
    var footerText = isAdmin
        ? "Internal motorcycle rental operations"
        : isStaff
            ? "Rental desk operations"
            : "Motorcycle rental system";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoBike</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebUI.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header>
            <nav class="navbar navbar-expand-lg app-navbar">
                <div class="container-fluid px-3 px-lg-4">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                        <span class="brand-mark">G</span>
                        <span class="brand-lockup">GoBike</span>
                        @if (!string.IsNullOrEmpty(roleLabel))
                        {
                            <span class="role-badge @roleClass">@roleLabel</span>
                        }
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                            <li class="nav-item">
                                <a class="nav-link @(currentPath == "/" || currentPath.StartsWith("/index") ? "active" : "")" asp-area="" asp-page="/Index">Dashboard</a>
                            </li>
                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentPath.StartsWith("/admin/staff") ? "active" : "")" href="/Admin/Staff">Staff</a>
                                </li>
                            }
                            @if (isAdmin || isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentPath.StartsWith("/motorcycle") ? "active" : "")" href="/Motorcycle">Motorcycles</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentPath.StartsWith("/customers") ? "active" : "")" href="/Customers">Customers</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentPath.StartsWith("/rentals") ? "active" : "")" href="/Rentals">Rentals</a>
                                </li>
                            }
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        @displayName
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="/Account/Profile">Profile</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="/Account/Logout">Logout</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-primary" asp-page="/Account/Login">Login</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main class="app-main">
            <div class="container-fluid px-3 px-lg-4">
                @RenderBody()
            </div>
        </main>

        <footer class="app-footer py-3">
            <div class="container-fluid px-3 px-lg-4 d-flex flex-column flex-sm-row justify-content-between gap-2 small">
                <span>&copy; 2026 GoBike</span>
                <span>@footerText</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
