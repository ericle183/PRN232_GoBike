@page "{id:int}"
@model WebUI.Pages.Motorcycle.DetailsModel
@using BusinessObjects.Enums
@{
    ViewData["Title"] = $"Motorcycle — {Model.Motorcycle.LicensePlate}";

    var badgeClass = Model.Motorcycle.Status switch
    {
        MotorcycleStatus.Available => "badge-available",
        MotorcycleStatus.Reserved => "badge-reserved",
        MotorcycleStatus.Rented => "badge-rented",
        MotorcycleStatus.Maintenance => "badge-maintenance",
        _ => "bg-light text-dark"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Motorcycle Details</h2>
    <a asp-page="./Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@Model.Motorcycle.LicensePlate — @Model.Motorcycle.Brand @Model.Motorcycle.Model</h5>
        <span class="badge @badgeClass fs-6">@Model.Motorcycle.StatusText</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-borderless">
                    <tr>
                        <th class="text-muted" style="width:180px">License Plate</th>
                        <td><strong>@Model.Motorcycle.LicensePlate</strong></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Brand</th>
                        <td>@Model.Motorcycle.Brand</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Model</th>
                        <td>@Model.Motorcycle.Model</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Vehicle Type</th>
                        <td>@Model.Motorcycle.VehicleTypeName</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Color</th>
                        <td>@Model.Motorcycle.Color</td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <table class="table table-borderless">
                    <tr>
                        <th class="text-muted" style="width:180px">Daily Rate</th>
                        <td><strong>@Model.Motorcycle.DailyRate.ToString("#,##0") VND</strong></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Mileage</th>
                        <td>@Model.Motorcycle.Mileage.ToString("#,##0") km</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Registration No</th>
                        <td>@(Model.Motorcycle.RegistrationNo ?? "—")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Created At</th>
                        <td>@Model.Motorcycle.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Updated At</th>
                        <td>@(Model.Motorcycle.UpdatedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Recent Rental History</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Rental Date</th>
                    <th>Expected Return</th>
                    <th>Actual Return</th>
                    <th>Status</th>
                    <th>Total Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Motorcycle.RecentRentals.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No rental history.</td></tr>
                }
                @foreach (var rental in Model.Motorcycle.RecentRentals)
                {
                    var rentalBadge = rental.Status switch
                    {
                        RentalStatus.Pending => "badge-maintenance",
                        RentalStatus.Active => "badge-available",
                        RentalStatus.Completed => "bg-secondary",
                        RentalStatus.Cancelled => "bg-danger",
                        _ => "bg-light text-dark"
                    };

                    <tr>
                        <td>@rental.Id</td>
                        <td>@rental.CustomerName</td>
                        <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                        <td>@rental.ExpectedReturnDate.ToString("dd/MM/yyyy")</td>
                        <td>@(rental.ActualReturnDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td><span class="badge @rentalBadge">@rental.StatusText</span></td>
                        <td>@rental.TotalAmount.ToString("#,##0") VND</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
