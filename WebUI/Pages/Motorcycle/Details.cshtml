@page "{id:int}"
@model WebUI.Pages.Motorcycle.DetailsModel
@using BusinessObjects.Enums
@{
    ViewData["Title"] = $"Motorcycle - {Model.Motorcycle.LicensePlate}";

    var badgeClass = Model.Motorcycle.Status switch
    {
        MotorcycleStatus.Available => "badge-available",
        MotorcycleStatus.Reserved => "badge-reserved",
        MotorcycleStatus.Rented => "badge-rented",
        MotorcycleStatus.Maintenance => "badge-maintenance",
        _ => "bg-light text-dark"
    };

    var imageUrl = string.IsNullOrWhiteSpace(Model.Motorcycle.ImageUrl)
        ? "/images/motorcycle-placeholder.svg"
        : Model.Motorcycle.ImageUrl;
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Fleet inventory</div>
        <h1>@Model.Motorcycle.LicensePlate</h1>
        <p class="page-subtitle">@Model.Motorcycle.Brand @Model.Motorcycle.Model</p>
    </div>
    <a asp-page="./Index" class="btn btn-outline-secondary">Back to list</a>
</div>

<div class="content-card mb-4">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-5 col-lg-4">
                <div class="motorcycle-image-wrap rounded">
                    <img src="@imageUrl" alt="@Model.Motorcycle.Brand @Model.Motorcycle.Model"
                         onerror="this.onerror=null; this.src='/images/motorcycle-placeholder.svg';" />
                    <span class="badge @badgeClass motorcycle-status">@Model.Motorcycle.StatusText</span>
                </div>
            </div>
            <div class="col-md-7 col-lg-8">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="page-kicker">Motorcycle details</div>
                        <h2 class="h4 mb-1">@Model.Motorcycle.Brand @Model.Motorcycle.Model</h2>
                        <div class="text-muted">@Model.Motorcycle.VehicleTypeName</div>
                    </div>
                    <span class="badge @badgeClass fs-6">@Model.Motorcycle.StatusText</span>
                </div>

                <div class="stat-grid">
                    <div class="stat-card shadow-none">
                        <div class="stat-label">Daily Rate</div>
                        <div class="stat-value">@Model.Motorcycle.DailyRate.ToString("#,##0")</div>
                        <div class="text-muted small">VND per day</div>
                    </div>
                    <div class="stat-card shadow-none">
                        <div class="stat-label">Mileage</div>
                        <div class="stat-value">@Model.Motorcycle.Mileage.ToString("#,##0")</div>
                        <div class="text-muted small">km</div>
                    </div>
                </div>

                <table class="table table-borderless mt-3">
                    <tr>
                        <th class="text-muted" style="width:180px">License Plate</th>
                        <td><strong>@Model.Motorcycle.LicensePlate</strong></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Color</th>
                        <td>@Model.Motorcycle.Color</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Registration No</th>
                        <td>@(Model.Motorcycle.RegistrationNo ?? "-")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Created At</th>
                        <td>@Model.Motorcycle.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Updated At</th>
                        <td>@(Model.Motorcycle.UpdatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="card-body p-0">
        <div class="px-3 py-3 border-bottom">
            <h5 class="mb-0">Recent Rental History</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Rental Date</th>
                        <th>Expected Return</th>
                        <th>Actual Return</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Motorcycle.RecentRentals.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state border-0 shadow-none">
                                    <strong>No rental history.</strong>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var rental in Model.Motorcycle.RecentRentals)
                    {
                        var rentalBadge = rental.Status switch
                        {
                            RentalStatus.Reserved => "badge-reserved",
                            RentalStatus.Active => "badge-available",
                            RentalStatus.Completed => "badge-completed",
                            RentalStatus.Cancelled => "badge-cancelled",
                            RentalStatus.NoShow => "badge-noshow",
                            _ => "bg-light text-dark"
                        };

                        <tr>
                            <td>#@rental.Id</td>
                            <td>@rental.CustomerName</td>
                            <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                            <td>@rental.ExpectedReturnDate.ToString("dd/MM/yyyy")</td>
                            <td>@(rental.ActualReturnDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td><span class="badge @rentalBadge">@rental.StatusText</span></td>
                            <td>@rental.TotalAmount.ToString("#,##0") VND</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
