@page
@model WebUI.Pages.Rentals.DetailsModel
@{
    ViewData["Title"] = "Rentals / Details";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Rental record</div>
        <h1>Rental Contract #@Model.Rental.Id</h1>
        <p class="page-subtitle">@Model.Rental.CustomerFullName - @Model.Rental.MotorcycleLicensePlate</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            @if (Model.Rental.Status == 1)
            {
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="Activate" asp-route-id="@Model.Rental.Id" class="btn btn-success">Activate</a>
                    <a asp-page="Cancel" asp-route-id="@Model.Rental.Id" class="btn btn-danger">Cancel</a>
                    <a asp-page="NoShow" asp-route-id="@Model.Rental.Id" class="btn btn-warning">No-show</a>
                }
                else
                {
                    <span class="badge badge-info align-self-center">Pending admin approval</span>
                }
            }
            else if (Model.Rental.Status == 2)
            {
                <a asp-page="Complete" asp-route-id="@Model.Rental.Id" class="btn btn-success">Complete</a>
            }
        }
        <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="content-card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">ID</dt>
                    <dd class="col-sm-8">#@Model.Rental.Id</dd>

                    <dt class="col-sm-4 text-muted">Customer</dt>
                    <dd class="col-sm-8">@Model.Rental.CustomerFullName</dd>

                    <dt class="col-sm-4 text-muted">Motorcycle</dt>
                    <dd class="col-sm-8">@Model.Rental.MotorcycleLicensePlate</dd>

                    <dt class="col-sm-4 text-muted">Rental Date</dt>
                    <dd class="col-sm-8">@Model.Rental.RentalDate.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4 text-muted">Expected Return</dt>
                    <dd class="col-sm-8">@Model.Rental.ExpectedReturnDate.ToString("dd/MM/yyyy")</dd>

                    @if (Model.Rental.ActualReturnDate.HasValue)
                    {
                        <dt class="col-sm-4 text-muted">Actual Return</dt>
                        <dd class="col-sm-8">@Model.Rental.ActualReturnDate.Value.ToString("dd/MM/yyyy")</dd>
                    }
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @WebUI.Pages.Rentals.DetailsModel.GetStatusBadgeClass(Model.Rental.Status)">
                            @WebUI.Pages.Rentals.DetailsModel.GetStatusName(Model.Rental.Status)
                        </span>
                    </dd>

                    <dt class="col-sm-4 text-muted">Daily Rate</dt>
                    <dd class="col-sm-8">@Model.Rental.DailyRate.ToString("N0") VND</dd>

                    <dt class="col-sm-4 text-muted">Total Amount</dt>
                    <dd class="col-sm-8">@Model.Rental.TotalAmount.ToString("N0") VND</dd>

                    <dt class="col-sm-4 text-muted">Deposit</dt>
                    <dd class="col-sm-8">@Model.Rental.DepositAmount.ToString("N0") VND</dd>

                    @if (Model.Rental.FinalAmount > 0)
                    {
                        <dt class="col-sm-4 text-muted">Final Amount</dt>
                        <dd class="col-sm-8">@Model.Rental.FinalAmount.ToString("N0") VND</dd>
                    }

                    @if (Model.Rental.StartMileage.HasValue)
                    {
                        <dt class="col-sm-4 text-muted">Start Mileage</dt>
                        <dd class="col-sm-8">@Model.Rental.StartMileage.Value.ToString("N0") km</dd>
                    }

                    @if (Model.Rental.EndMileage.HasValue)
                    {
                        <dt class="col-sm-4 text-muted">End Mileage</dt>
                        <dd class="col-sm-8">@Model.Rental.EndMileage.Value.ToString("N0") km</dd>
                    }

                    <dt class="col-sm-4 text-muted">Created By</dt>
                    <dd class="col-sm-8">@Model.Rental.CreatedBy</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Rental.Notes))
        {
            <hr />
            <dl class="row mb-0">
                <dt class="col-sm-2 text-muted">Notes</dt>
                <dd class="col-sm-10">@Model.Rental.Notes</dd>
            </dl>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="card-body">
                <div class="page-heading mb-3">
                    <div>
                        <div class="page-kicker">Payments</div>
                        <h2>Payment History</h2>
                    </div>
                </div>

                @if (Model.Rental.Payments.Any())
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Method</th>
                                    <th>Amount</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in Model.Rental.Payments)
                                {
                                    <tr>
                                        <td>
                                            <strong>@payment.PaymentType</strong>
                                            @if (!string.IsNullOrWhiteSpace(payment.Note))
                                            {
                                                <div class="text-muted small">@payment.Note</div>
                                            }
                                        </td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>@payment.Amount.ToString("N0") VND</td>
                                        <td>@payment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state compact">
                        <strong>No payments recorded.</strong>
                        <div>Deposit, additional payment, or refund records will appear here.</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="card-body">
                <div class="page-heading mb-3">
                    <div>
                        <div class="page-kicker">Inspections</div>
                        <h2>Vehicle Inspections</h2>
                    </div>
                </div>

                @if (Model.Rental.Inspections.Any())
                {
                    <div class="inspection-list">
                        @foreach (var inspection in Model.Rental.Inspections)
                        {
                            <div class="inspection-item">
                                <div class="d-flex justify-content-between gap-3">
                                    <div>
                                        <strong>@inspection.InspectionType</strong>
                                        <div class="text-muted small">@inspection.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                    <span class="badge @(inspection.HasDamage ? "badge-cancelled" : "badge-success")">
                                        @(inspection.HasDamage ? "Damage" : "Clear")
                                    </span>
                                </div>
                                <dl class="row mt-3 mb-0">
                                    <dt class="col-sm-4 text-muted">Mileage</dt>
                                    <dd class="col-sm-8">@inspection.Mileage.ToString("N0") km</dd>

                                    <dt class="col-sm-4 text-muted">Fuel</dt>
                                    <dd class="col-sm-8">@inspection.FuelLevel</dd>

                                    <dt class="col-sm-4 text-muted">Condition</dt>
                                    <dd class="col-sm-8">@inspection.VehicleCondition</dd>

                                    @if (!string.IsNullOrWhiteSpace(inspection.DamageDescription))
                                    {
                                        <dt class="col-sm-4 text-muted">Damage</dt>
                                        <dd class="col-sm-8">@inspection.DamageDescription</dd>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(inspection.AccessoriesNote))
                                    {
                                        <dt class="col-sm-4 text-muted">Accessories</dt>
                                        <dd class="col-sm-8">@inspection.AccessoriesNote</dd>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(inspection.Note))
                                    {
                                        <dt class="col-sm-4 text-muted">Note</dt>
                                        <dd class="col-sm-8">@inspection.Note</dd>
                                    }
                                </dl>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact">
                        <strong>No inspections recorded.</strong>
                        <div>Before-rental and after-return inspections will appear here.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
