@page "{id:int?}"
@model WebUI.Pages.Rentals.ActivateModel
@{
    ViewData["Title"] = "Rentals / Activate";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Activate Rental</h1>
    <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h2 class="h6 mb-0">Confirm Activation</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-4 text-muted">Motorcycle</dt>
            <dd class="col-sm-8">@Model.Rental.MotorcycleLicensePlate</dd>

            <dt class="col-sm-4 text-muted">Rental Date</dt>
            <dd class="col-sm-8">@Model.Rental.RentalDate.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-bold" for="StartMileage">
                    Start Mileage (km) <span style="color: #EF4444;">*</span>
                </label>
                <input class="form-control" id="StartMileage" type="number" min="0" asp-for="StartMileage" />
                <span asp-validation-for="StartMileage" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Activate</button>
                <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
