@page "{id:int?}"
@model WebUI.Pages.Rentals.CancelModel
@{
    ViewData["Title"] = "Rentals / Cancel";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Rental cancellation</div>
        <h1>Cancel Rental</h1>
        <p class="page-subtitle">Cancel a reserved contract and record the refund details.</p>
    </div>
    <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="content-card">
    <div class="card-body">
        <p>Are you sure you want to cancel this rental contract? The motorcycle will be set back to <strong>Available</strong>.</p>

        <dl class="row mb-3">
            <dt class="col-sm-4 text-muted">Customer</dt>
            <dd class="col-sm-8">@Model.Rental.CustomerFullName</dd>

            <dt class="col-sm-4 text-muted">Motorcycle</dt>
            <dd class="col-sm-8">@Model.Rental.MotorcycleLicensePlate</dd>

            <dt class="col-sm-4 text-muted">Current Status</dt>
            <dd class="col-sm-8">@WebUI.Pages.Rentals.CancelModel.GetStatusName(Model.Rental.Status)</dd>
        </dl>

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-bold" for="Reason">
                    Cancellation Reason <span style="color: #EF4444;">*</span>
                </label>
                <textarea class="form-control" id="Reason" rows="3" asp-for="Reason"></textarea>
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="RefundPaymentMethod">Refund Method</label>
                        <select class="form-select" id="RefundPaymentMethod" asp-for="RefundPaymentMethod">
                            <option value="1">Cash</option>
                            <option value="2">Bank Transfer</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="RefundPaymentNote">Refund Note</label>
                        <input class="form-control" id="RefundPaymentNote" asp-for="RefundPaymentNote" />
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Confirm Cancel</button>
                <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
