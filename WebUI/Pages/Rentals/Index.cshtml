@page
@model WebUI.Pages.Rentals.IndexModel
@{
    ViewData["Title"] = "Rentals / List";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Rental operations</div>
        <h1>Rental Contracts</h1>
        <p class="page-subtitle">Track reservations, active rentals, returns, and settlements.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <div class="d-flex gap-2">
            <a asp-page="RentNow" class="btn btn-primary">Rent now</a>
            <a asp-page="Create" class="btn btn-outline-primary">Create reservation</a>
        </div>
    }
</div>

<div class="filter-panel mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Customer</label>
            <select class="form-select" name="FilterCustomerId">
                <option value="">All customers</option>
                @foreach (var c in Model.Customers)
                {
                    <option value="@c.Id" selected="@(Model.FilterCustomerId == c.Id)">@c.FullName</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Motorcycle</label>
            <select class="form-select" name="FilterMotorcycleId">
                <option value="">All motorcycles</option>
                @foreach (var m in Model.Motorcycles)
                {
                    <option value="@m.Id" selected="@(Model.FilterMotorcycleId == m.Id)">@m.LicensePlate</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Status</label>
            <select class="form-select" name="FilterStatus">
                <option value="">All statuses</option>
                <option value="Reserved" selected="@(Model.FilterStatus == "Reserved")">Reserved</option>
                <option value="Active" selected="@(Model.FilterStatus == "Active")">Active</option>
                <option value="Completed" selected="@(Model.FilterStatus == "Completed")">Completed</option>
                <option value="Cancelled" selected="@(Model.FilterStatus == "Cancelled")">Cancelled</option>
                <option value="NoShow" selected="@(Model.FilterStatus == "NoShow")">NoShow</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">From</label>
            <input type="date" class="form-control" name="FilterFromDate" value="@(Model.FilterFromDate?.ToString("yyyy-MM-dd") ?? "")" />
        </div>
        <div class="col-md-2">
            <label class="form-label">To</label>
            <input type="date" class="form-control" name="FilterToDate" value="@(Model.FilterToDate?.ToString("yyyy-MM-dd") ?? "")" />
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Apply filters</button>
        </div>
    </form>
</div>

@if (Model.Rentals.Any())
{
    <div class="data-card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Motorcycle</th>
                        <th>Rental Date</th>
                        <th>Expected Return</th>
                        <th>Daily Rate</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Created By</th>
                        <th style="width: 100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rental in Model.Rentals)
                    {
                        <tr>
                            <td class="text-muted">#@rental.Id</td>
                            <td><strong>@rental.CustomerFullName</strong></td>
                            <td>@rental.MotorcycleLicensePlate</td>
                            <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                            <td>@rental.ExpectedReturnDate.ToString("dd/MM/yyyy")</td>
                            <td>@rental.DailyRate.ToString("N0") VND</td>
                            <td>@rental.TotalAmount.ToString("N0") VND</td>
                            <td>
                                <span class="badge @WebUI.Pages.Rentals.IndexModel.GetStatusBadgeClass(rental.Status)">
                                    @WebUI.Pages.Rentals.IndexModel.GetStatusName(rental.Status)
                                </span>
                            </td>
                            <td>@rental.CreatedBy</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-page="Details" asp-route-id="@rental.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <strong>No rental contracts found.</strong>
        <div>Try changing the filters or create a new rental contract.</div>
    </div>
}
