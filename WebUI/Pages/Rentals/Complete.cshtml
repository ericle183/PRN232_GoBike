@page "{id:int?}"
@model WebUI.Pages.Rentals.CompleteModel
@{
    ViewData["Title"] = "Rentals / Complete";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Rental return</div>
        <h1>Complete Rental</h1>
        <p class="page-subtitle">Record the return inspection and settle the contract.</p>
    </div>
    <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="content-card">
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-4 text-muted">Motorcycle</dt>
            <dd class="col-sm-8">@Model.Rental.MotorcycleLicensePlate</dd>

            <dt class="col-sm-4 text-muted">Rental Date</dt>
            <dd class="col-sm-8">@Model.Rental.RentalDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4 text-muted">Expected Return</dt>
            <dd class="col-sm-8">@Model.Rental.ExpectedReturnDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4 text-muted">Daily Rate</dt>
            <dd class="col-sm-8">@Model.Rental.DailyRate.ToString("N0") VND</dd>
        </dl>

        <form method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="ActualReturnDate">
                            Actual Return Date <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="ActualReturnDate" type="date" asp-for="ActualReturnDate" />
                        <span asp-validation-for="ActualReturnDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="EndMileage">
                            End Mileage (km) <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="EndMileage" type="number" min="0" asp-for="EndMileage" oninput="estimateFinalAmount()" />
                        <span asp-validation-for="EndMileage" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="FuelLevel">
                            Fuel Level <span style="color: #EF4444;">*</span>
                        </label>
                        <select class="form-select" id="FuelLevel" asp-for="FuelLevel">
                            <option value="Full">Full</option>
                            <option value="3/4">3/4</option>
                            <option value="1/2">1/2</option>
                            <option value="1/4">1/4</option>
                            <option value="Empty">Empty</option>
                        </select>
                        <span asp-validation-for="FuelLevel" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="VehicleCondition">
                            Vehicle Condition <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="VehicleCondition" asp-for="VehicleCondition" />
                        <span asp-validation-for="VehicleCondition" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="MotorcycleStatusAfterReturn">Status After Return</label>
                        <select class="form-select" id="MotorcycleStatusAfterReturn" asp-for="MotorcycleStatusAfterReturn">
                            <option value="1">Available</option>
                            <option value="4">Maintenance</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" id="HasDamage" asp-for="HasDamage" />
                <label class="form-check-label fw-bold" for="HasDamage">Damage found after return</label>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="DamageFee">Damage Fee</label>
                        <input class="form-control" id="DamageFee" type="number" min="0" step="1000" asp-for="DamageFee" />
                        <span asp-validation-for="DamageFee" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="DamageDescription">Damage Description</label>
                        <textarea class="form-control" id="DamageDescription" rows="3" asp-for="DamageDescription"></textarea>
                        <span asp-validation-for="DamageDescription" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="OtherFee">Other Fee</label>
                        <input class="form-control" id="OtherFee" type="number" min="0" step="1000" asp-for="OtherFee" />
                        <span asp-validation-for="OtherFee" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="OtherFeeDescription">Other Fee Description</label>
                        <textarea class="form-control" id="OtherFeeDescription" rows="3" asp-for="OtherFeeDescription"></textarea>
                        <span asp-validation-for="OtherFeeDescription" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="DiscountAmount">Discount Amount</label>
                        <input class="form-control" id="DiscountAmount" type="number" min="0" step="1000" asp-for="DiscountAmount" />
                        <span asp-validation-for="DiscountAmount" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="SettlementPaymentMethod">Settlement Method</label>
                        <select class="form-select" id="SettlementPaymentMethod" asp-for="SettlementPaymentMethod">
                            <option value="1">Cash</option>
                            <option value="2">Bank Transfer</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="SettlementPaymentNote">Settlement Note</label>
                        <input class="form-control" id="SettlementPaymentNote" asp-for="SettlementPaymentNote" />
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" for="DiscountReason">Discount Reason</label>
                <input class="form-control" id="DiscountReason" asp-for="DiscountReason" />
                <span asp-validation-for="DiscountReason" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="AccessoriesNote">Accessories Note</label>
                        <textarea class="form-control" id="AccessoriesNote" rows="2" asp-for="AccessoriesNote"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="InspectionNote">Inspection Note</label>
                        <textarea class="form-control" id="InspectionNote" rows="2" asp-for="InspectionNote"></textarea>
                    </div>
                </div>
            </div>

            <div class="alert alert-info" id="finalAmountPreview" style="display: none;">
                <strong>Estimated Final Amount:</strong> <span id="finalAmountDisplay">—</span> VND
                <br /><small class="text-muted">Includes late fees if return date exceeds expected return date.</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Complete</button>
                <a asp-page="Details" asp-route-id="@Model.Rental.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function estimateFinalAmount() {
            var rentalDate = new Date('@Model.Rental.RentalDate.ToString("yyyy-MM-dd")');
            var expectedReturn = new Date('@Model.Rental.ExpectedReturnDate.ToString("yyyy-MM-dd")');
            var actualReturn = document.getElementById('ActualReturnDate').value;
            if (!actualReturn) return;
            var endMileage = parseInt(document.getElementById('EndMileage').value);
            var dailyRate = @Model.Rental.DailyRate;
            if (!endMileage && endMileage !== 0) return;

            var actualReturnDate = new Date(actualReturn);
            var totalDays = Math.ceil((expectedReturn - rentalDate) / (1000 * 60 * 60 * 24)) + 1;
            var actualDays = Math.ceil((actualReturnDate - rentalDate) / (1000 * 60 * 60 * 24)) + 1;
            var daysDiff = Math.max(0, actualDays - totalDays);
            var lateFees = daysDiff * dailyRate;
            var estimatedFinal = @Model.Rental.DailyRate * actualDays + lateFees;

            var preview = document.getElementById('finalAmountPreview');
            document.getElementById('finalAmountDisplay').textContent = Math.round(estimatedFinal).toLocaleString();
            preview.style.display = 'block';
        }
    </script>
}
