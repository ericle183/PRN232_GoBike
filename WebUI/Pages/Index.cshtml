@page
@using WebUI.Helpers
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity?.IsAuthenticated == true)
{
    var name = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
        ?? User.Identity?.Name
        ?? "there";
    var isAdmin = AuthorizationHelper.IsAdmin(User);
    var isStaff = User.IsInRole("Staff");
    var dashboardKicker = isAdmin ? "Operations control" : "Today at the rental desk";
    var dashboardSubtitle = isAdmin
        ? "Approve reservations, monitor fleet health, and manage operational access."
        : "Create customers, prepare rentals, and complete vehicle returns.";

    <section class="hero-panel mb-4">
        <div class="page-heading mb-0">
            <div>
                <div class="page-kicker">@dashboardKicker</div>
                <h1>Welcome back, @name</h1>
                <p class="page-subtitle">@dashboardSubtitle</p>
            </div>
        </div>
    </section>

    <section class="dashboard-metrics mb-4">
        <div class="dashboard-metric">
            <div class="stat-label">New customers</div>
            <div class="stat-value">@Model.NewCustomersThisWeek</div>
            <div class="text-muted small">Registered this week</div>
        </div>
        <div class="dashboard-metric">
            <div class="stat-label">Rentals this week</div>
            <div class="stat-value">@Model.RentalsThisWeek</div>
            <div class="text-muted small">Reservations and active rentals</div>
        </div>
        <div class="dashboard-metric">
            <div class="stat-label">Active rentals</div>
            <div class="stat-value">@Model.ActiveRentals</div>
            <div class="text-muted small">Motorcycles currently out</div>
        </div>
        <div class="dashboard-metric">
            <div class="stat-label">Most rented type</div>
            <div class="stat-value dashboard-type-name">@Model.TopVehicleTypeName</div>
            <div class="text-muted small">@Model.TopVehicleTypeRentalCount rental(s)</div>
        </div>
    </section>

    <section class="dashboard-panels mb-4">
        <div class="dashboard-panel">
            <div class="dashboard-panel-header">
                <div>
                    <div class="page-kicker">Customer trend</div>
                    <h2>Customers by Week</h2>
                </div>
            </div>
            @{
                var maxCustomers = Math.Max(1, Model.WeeklyCustomers.Any() ? Model.WeeklyCustomers.Max(x => x.Count) : 1);
            }
            <div class="weekly-chart">
                @foreach (var week in Model.WeeklyCustomers)
                {
                    var width = Math.Max(6, (int)Math.Round((double)week.Count / maxCustomers * 100));
                    <div class="weekly-row">
                        <div class="weekly-label">
                            <strong>@week.Label</strong>
                            <span>@week.StartDate.ToString("dd/MM") - @week.EndDate.ToString("dd/MM")</span>
                        </div>
                        <div class="weekly-track">
                            <div class="weekly-bar" style="width: @width%"></div>
                        </div>
                        <div class="weekly-count">@week.Count</div>
                    </div>
                }
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel-header">
                <div>
                    <div class="page-kicker">Rental demand</div>
                    <h2>Top Motorcycle Types</h2>
                </div>
            </div>
            @if (Model.TopVehicleTypes.Any())
            {
                var maxTypeRentals = Math.Max(1, Model.TopVehicleTypes.Max(x => x.RentalCount));
                <div class="type-rank-list">
                    @foreach (var type in Model.TopVehicleTypes)
                    {
                        var width = Math.Max(8, (int)Math.Round((double)type.RentalCount / maxTypeRentals * 100));
                        <div class="type-rank-item">
                            <div class="type-rank-top">
                                <strong>@type.VehicleTypeName</strong>
                                <span>@type.RentalCount rental(s)</span>
                            </div>
                            <div class="type-track">
                                <div class="type-bar" style="width: @width%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state compact">
                    <strong>No rental demand yet.</strong>
                    <div>Completed or active contracts will appear here.</div>
                </div>
            }
        </div>
    </section>

    <section class="stat-grid mb-4">
        @if (isAdmin)
        {
            <a class="stat-card" asp-page="/Rentals/Index" asp-route-FilterStatus="Reserved">
                <div class="stat-label">Approval queue</div>
                <div class="stat-value">Reserved</div>
                <div class="text-muted small">Activate, cancel, or mark no-show.</div>
            </a>
            <a class="stat-card" asp-page="/Motorcycle/Index">
                <div class="stat-label">Fleet control</div>
                <div class="stat-value">Motorcycles</div>
                <div class="text-muted small">Create, deactivate, and update status.</div>
            </a>
            <a class="stat-card" asp-page="/Admin/Staff/Index">
                <div class="stat-label">Admin</div>
                <div class="stat-value">Staff</div>
                <div class="text-muted small">Create and manage staff accounts.</div>
            </a>
            <a class="stat-card" asp-page="/Customers/Index">
                <div class="stat-label">Customer records</div>
                <div class="stat-value">Profiles</div>
                <div class="text-muted small">Review renter identity and licenses.</div>
            </a>
        }
        else if (isStaff)
        {
            <a class="stat-card" asp-page="/Rentals/RentNow">
                <div class="stat-label">Walk-in rental</div>
                <div class="stat-value">Rent now</div>
                <div class="text-muted small">Create active rentals at the desk.</div>
            </a>
            <a class="stat-card" asp-page="/Rentals/Create">
                <div class="stat-label">Reservation</div>
                <div class="stat-value">Reserve</div>
                <div class="text-muted small">Prepare bookings for admin approval.</div>
            </a>
            <a class="stat-card" asp-page="/Rentals/Index" asp-route-FilterStatus="Active">
                <div class="stat-label">Returns</div>
                <div class="stat-value">Complete</div>
                <div class="text-muted small">Record return inspection and settlement.</div>
            </a>
            <a class="stat-card" asp-page="/Customers/Create">
                <div class="stat-label">Customer desk</div>
                <div class="stat-value">Add</div>
                <div class="text-muted small">Register renter identity and license.</div>
            </a>
        }
    </section>
}
else
{
    <section class="hero-panel mx-auto" style="max-width: 760px;">
        <div class="page-kicker">GoBike</div>
        <h1 class="mb-2">Motorcycle rental operations</h1>
        <p class="page-subtitle mb-4">Sign in to manage customers, rentals, inspections, payments, and fleet status.</p>
        <a class="btn btn-primary" asp-page="/Account/Login">Login</a>
    </section>
}
