@page
@model WebUI.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers / List";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Customer records</div>
        <h1>Customers</h1>
        <p class="page-subtitle">Search renter profiles, identity numbers, and contact details.</p>
    </div>
    <a asp-page="Create" class="btn btn-primary">Add customer</a>
</div>

<div class="filter-panel mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-9">
            <label class="form-label">Search</label>
            <input type="text" name="search" class="form-control"
                   placeholder="Name, CCCD, or phone number"
                   value="@Model.SearchQuery" />
        </div>
        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>
</div>

@if (Model.Customers.Any())
{
    <div class="data-card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>CCCD</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Age</th>
                        <th>Created At</th>
                        <th style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model.Customers)
                    {
                        <tr>
                            <td><strong>@customer.FullName</strong></td>
                            <td class="text-muted">@WebUI.Pages.Customers.IndexModel.Mask(customer.Cccd)</td>
                            <td>@WebUI.Pages.Customers.IndexModel.Mask(customer.PhoneNumber)</td>
                            <td>@customer.Email</td>
                            <td>@WebUI.Pages.Customers.IndexModel.CalculateAge(customer.DateOfBirth)</td>
                            <td>@customer.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-page="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                    <a asp-page="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-page="Delete" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3" aria-label="Pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchQuery">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.CurrentPage of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchQuery">Next</a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="empty-state">
        <strong>No customers found.</strong>
        <div>Try another keyword or add a new customer profile.</div>
    </div>
}
