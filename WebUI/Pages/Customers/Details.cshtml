@page
@model WebUI.Pages.Customers.DetailsModel
@{
    ViewData["Title"] = "Customers / Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Customer Details</h1>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Customer.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Full Name</dt>
                    <dd class="col-sm-8">@Model.Customer.FullName</dd>

                    <dt class="col-sm-4 text-muted">CCCD</dt>
                    <dd class="col-sm-8">@Model.Customer.Cccd</dd>

                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">@Model.Customer.PhoneNumber</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Customer.Email</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">@Model.Customer.Address</dd>

                    <dt class="col-sm-4 text-muted">Date of Birth</dt>
                    <dd class="col-sm-8">@Model.Customer.DateOfBirth.ToString("dd/MM/yyyy") (@WebUI.Pages.Customers.DetailsModel.CalculateAge(Model.Customer.DateOfBirth) years old)</dd>

                    <dt class="col-sm-4 text-muted">Driver License</dt>
                    <dd class="col-sm-8">@Model.Customer.DriverLicenseNo</dd>

                    <dt class="col-sm-4 text-muted">Created At</dt>
                    <dd class="col-sm-8">@Model.Customer.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (Model.RentalHistory.Any())
{
    <div class="card">
        <div class="card-header">
            <h2 class="h6 mb-0">Rental History</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Rental Date</th>
                        <th>Motorcycle</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rental in Model.RentalHistory)
                    {
                        <tr>
                            <td>@rental.Id</td>
                            <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                            <td>@rental.MotorcyclePlate</td>
                            @{
                                var badgeClass = rental.Status switch
                                {
                                    2 => "badge-success",
                                    1 => "badge-warning",
                                    3 => "badge-neutral",
                                    4 => "badge-error",
                                    _ => "badge-info"
                                };
                                var statusName = rental.Status switch
                                {
                                    1 => "Pending",
                                    2 => "Active",
                                    3 => "Completed",
                                    4 => "Cancelled",
                                    _ => "Unknown"
                                };
                            }
                            <span class="badge @badgeClass">@statusName</span>
                            <td>@rental.TotalAmount.ToString("N0") VND</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No rental history found for this customer.</div>
}
