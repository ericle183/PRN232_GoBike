@page
@model WebUI.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Customers / Create";
}

<div class="page-heading">
    <div>
        <div class="page-kicker">Customer records</div>
        <h1>Create Customer</h1>
        <p class="page-subtitle">Capture renter identity, contact, age, and driver license information.</p>
    </div>
    <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="content-card">
    <div class="card-body">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="FullName">
                            Full Name <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="FullName" asp-for="Form.FullName" />
                        <span asp-validation-for="Form.FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="Cccd">
                            CCCD <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="Cccd" asp-for="Form.Cccd" placeholder="12 digits, e.g. 091234567891" />
                        <span asp-validation-for="Form.Cccd" class="text-danger"></span>
                        <div class="form-text">Must be exactly 12 digits.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="PhoneNumber">
                            Phone Number <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="PhoneNumber" asp-for="Form.PhoneNumber" placeholder="e.g. 0912345678" />
                        <span asp-validation-for="Form.PhoneNumber" class="text-danger"></span>
                        <div class="form-text">10-11 digits starting with 0.</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold" for="Email">
                            Email <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="Email" type="email" asp-for="Form.Email" />
                        <span asp-validation-for="Form.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="DateOfBirth">
                            Date of Birth <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="DateOfBirth" type="date" asp-for="Form.DateOfBirth" />
                        <span asp-validation-for="Form.DateOfBirth" class="text-danger"></span>
                        <div class="form-text">Customer must be at least 18 years old.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="Address">Address</label>
                        <input class="form-control" id="Address" asp-for="Form.Address" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="DriverLicenseNo">
                            Driver License <span style="color: #EF4444;">*</span>
                        </label>
                        <input class="form-control" id="DriverLicenseNo" asp-for="Form.DriverLicenseNo" />
                        <span asp-validation-for="Form.DriverLicenseNo" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create customer</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            var dob = document.getElementById('DateOfBirth').value;
            if (dob) {
                var birthDate = new Date(dob);
                var today = new Date();
                var age = today.getFullYear() - birthDate.getFullYear();
                var m = today.getMonth() - birthDate.getMonth();
                if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) age--;
                if (age < 18) {
                    e.preventDefault();
                    alert('Customer must be at least 18 years old.');
                }
            }
        });
    </script>
}
